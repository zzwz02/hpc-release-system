# QA AI analysis LLM configuration.
# Copy this file to qa_llm.env and edit values. qa_llm.env is ignored by git.
# Requires OpenAI Python SDK: python -m pip install openai
# The endpoint must be OpenAI-compatible and usually ends with /v1.

QA_LLM_BASE_URL=http://10.x.x.x:8000/v1
QA_LLM_MODEL=your-model-name
QA_LLM_API_KEY=
